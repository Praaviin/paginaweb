---
import { site } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  image?: string;
}

const {
  title = site.name,
  description = "Centro medico multidisciplinar en Costa Adeje con fisioterapia, osteopatia, acupuntura, nutricion y mas.",
  canonicalPath = "/",
  image
} = Astro.props;

const canonical = new URL(canonicalPath, site.url).toString();
const fullTitle = title.includes(site.name) ? title : `${title} | ${site.name}`;
const ogImage = image ? new URL(image, site.url).toString() : undefined;
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta property="og:type" content="website" />
<meta property="og:site_name" content={site.name} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
{ogImage && <meta property="og:image" content={ogImage} />}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
{ogImage && <meta name="twitter:image" content={ogImage} />}
