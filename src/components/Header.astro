---
import { mainNavigation } from "../data/navigation";
import { site } from "../data/site";
import { resolveImage } from "../utils/images";

const logo = resolveImage("images/brand/logo.png");
const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="shell site-header__inner">
    <a class="site-header__brand" href="/" aria-label="Ir al inicio de Centro Medico Miraverde">
      <span>CENTRO MEDICO MIRAVERDE</span>
    </a>

    <nav aria-label="Principal" class="site-header__nav">
      <ul>
        {mainNavigation.map((item) => (
          <li>
            <a href={item.href} aria-current={currentPath === item.href ? "page" : undefined}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
