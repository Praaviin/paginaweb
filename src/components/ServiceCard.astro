---
interface Props {
  title: string;
  excerpt: string;
  href: string;
}

const { title, excerpt, href } = Astro.props;

const iconMap: Record<string, string> = {
  Fisioterapia: "M21 12h-6m3-3-3 3m-9 0a3 3 0 1 1 0-6 3 3 0 0 1 0 6Zm0 0a9 9 0 1 0-18 0 9 9 0 0 0 18 0Z",
  Osteopatia: "M12 3v18M3 12h18M7 7l10 10M17 7 7 17",
  Quiropractica: "M12 3c2 2 3 4.5 3 7.5S14 16 12 18c-2-2-3-4.5-3-7.5S10 5 12 3Z",
  Acupuntura: "M12 3v18M9.5 7.5 12 5l2.5 2.5M9.5 16.5 12 19l2.5-2.5",
  Nutricion: "M12 3c4 0 7 2.8 7 6.8 0 5.1-4.8 8.8-7 11.2-2.2-2.4-7-6.1-7-11.2C5 5.8 8 3 12 3Z",
  Masaje: "M6 14c1.2-2.5 3.3-4 6-4s4.8 1.5 6 4M8 10c.7-1.4 2-2.2 4-2.2S15.3 8.6 16 10",
  "Tecnologia avanzada": "M8 7V5m8 2V5M6 9h12v10H6zM9 12h6m-6 3h4",
  Preparto: "M12 5c3.5 0 6 2.4 6 5.6 0 3.8-3.4 6.1-6 8.4-2.6-2.3-6-4.6-6-8.4C6 7.4 8.5 5 12 5Z",
  Psicologia: "M12 4a7 7 0 1 0 7 7c0-1.2-.3-2.2-.8-3.2-.8 1-2 1.7-3.4 1.7-2.5 0-4.5-2-4.5-4.5 0-.3 0-.7.1-1A7 7 0 0 0 12 4Z",
  "Apoyo a la lactancia": "M12 4c4.2 0 7 2.8 7 6.5 0 4.7-4.4 7.2-7 9.5-2.6-2.3-7-4.8-7-9.5C5 6.8 7.8 4 12 4Z"
};

const iconPath = iconMap[title] ?? "M12 4 19 8v8l-7 4-7-4V8l7-4Z";
---

<article class="service-feature-card">
  <a href={href} class="service-feature-card__link">
    <div class="service-feature-card__content">
      <span class="service-feature-card__symbol" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
          <path d={iconPath}></path>
        </svg>
      </span>

      <div class="service-feature-card__copy">
        <h3 class="service-feature-card__title">{title}</h3>
        <p class="service-feature-card__excerpt">{excerpt}</p>
      </div>

      <div class="service-feature-card__footer">
        <span class="service-feature-card__link-text">Ver mas</span>
        <span class="service-feature-card__icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </span>
      </div>
    </div>
  </a>
</article>
