---
import { getCollection } from "astro:content";
import FeaturedServicesCarousel from "../components/FeaturedServicesCarousel.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import TeamCard from "../components/TeamCard.astro";
import ContactMap from "../components/ContactMap.astro";
import FAQ from "../components/FAQ.astro";
import WhatsAppCTA from "../components/WhatsAppCTA.astro";
import IndibaPopup from "../components/IndibaPopup.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPageEntry } from "../utils/content";
import { resolveImage } from "../utils/images";

const page = await getPageEntry("home");
const services = (await getCollection("services")).sort((a, b) => a.data.order - b.data.order);
const team = (await getCollection("team")).sort((a, b) => a.data.order - b.data.order);

// Custom logic to promote Priti Balani to the absolute center of the homepage grid
const priti = team.find(member => member.data.name === "Priti Balani Balani");
const others = team.filter(member => member.data.name !== "Priti Balani Balani");

// Construct a 3-person array with Priti deliberately injected into the center [index 1]
const homepageTeamVars = priti ? [others[0], priti, others[1]] : team.slice(0, 3);

const heroImage = resolveImage(page.data.heroImage);
---

<BaseLayout
  title={page.data.seoTitle ?? page.data.title}
  description={page.data.seoDescription ?? page.data.description}
  canonicalPath="/"
  image={heroImage}
>
  <Hero
    eyebrow="Centro medico en Costa Adeje"
    title="Centro medico en Costa Adeje"
    intro="Clinica multidisciplinar con servicios de fisioterapia, osteopatia, psicologia, nutricion, preparacion al parto y mas, adaptados a tus necesidades."
    image={heroImage}
    imageAlt="Servicio de fisioterapia en Centro Medico Miraverde"
  >
    <div class="button-row">
      <a class="button button--primary" href="/servicios">Ver todos los servicios</a>
      <a class="button button--ghost" href="/contacto">Como pedir cita</a>
    </div>
  </Hero>

  <Section class="section--alternate">
    <div class="services-section-head">
      <header class="section__header section__header--compact">
        <h2>Servicios de la clinica</h2>
        <p>Explora nuestras especialidades y encuentra la atencion que mejor se adapta a lo que necesitas.</p>
      </header>
    </div>

    <FeaturedServicesCarousel
      items={services.map((service) => ({
        title: service.data.title,
        excerpt: service.data.excerpt,
        href: `/servicios/${service.slug}`
      }))}
    />
  </Section>

  <Section>
    <div class="services-section-head">
      <header class="section__header section__header--compact">
        <h2>Equipo multidisciplinar</h2>
        <p>Conoce al equipo de especialistas dedicados a tu bienestar.</p>
      </header>
    </div>

    <div class="elegant-grid" style="margin-bottom: 2rem; align-items: center;">
      {homepageTeamVars.map((member, index) => (
        <TeamCard
          name={member.data.name}
          role={member.data.role}
          excerpt={member.data.excerpt}
          specialties={member.data.specialties}
          image={resolveImage(member.data.photo)}
          isFeatured={index === 1} 
        />
      ))}
    </div>
    
    <div style="text-align: center; margin-top: 1rem;">
      <a class="text-link" href="/equipo" style="font-size: 1.1rem; display: inline-flex; align-items: center; gap: 0.5rem; justify-content: center;">
        Ver equipo completo
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
  </Section>

  <Section class="section--alternate" title="Donde estamos" subtitle="Visitanos en el corazon de Costa Adeje.">
    <ContactMap />
  </Section>

  <FAQ />
  <WhatsAppCTA />
  <IndibaPopup />
</BaseLayout>
