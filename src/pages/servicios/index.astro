---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import Section from "../../components/Section.astro";
import ServiceCard from "../../components/ServiceCard.astro";

const services = (await getCollection("services")).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Servicios"
  description="Explora las especialidades del Centro Medico Miraverde y encuentra la atencion que mejor se ajusta a tus necesidades."
  canonicalPath="/servicios"
>
  <Hero
    eyebrow="Especialidades"
    title="Servicios organizados por areas de cuidado"
    intro="Cada tratamiento cuenta con su propia pagina para que la informacion sea clara, ordenada y facil de consultar."
    image="https://images.unsplash.com/photo-1576091160550-2173dba999ef?q=80&w=2070&auto=format&fit=crop"
  />

  <Section title="Todas las especialidades">
    <div class="elegant-grid">
      {services.map((service) => (
        <ServiceCard
          title={service.data.title}
          excerpt={service.data.excerpt}
          href={`/servicios/${service.slug}`}
        />
      ))}
    </div>
  </Section>
</BaseLayout>
