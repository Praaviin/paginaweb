---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import WhatsAppCTA from "../components/WhatsAppCTA.astro";
import { site } from "../data/site";
import { getPageEntry } from "../utils/content";
import { resolveImage } from "../utils/images";

const page = await getPageEntry("centro");
const { Content } = await page.render();
const heroImage = resolveImage(page.data.heroImage);
const gallery = [
  { src: resolveImage("images/centre/entrada-centro.jpg"), alt: "Entrada del centro" },
  { src: resolveImage("images/centre/interior-1.jpg"), alt: "Espacio interior del centro" },
  { src: resolveImage("images/centre/interior-2.jpg"), alt: "Area de atencion del centro" }
].filter((item): item is { src: string; alt: string } => Boolean(item.src));
---

<BaseLayout
  title={page.data.seoTitle ?? page.data.title}
  description={page.data.seoDescription ?? page.data.description}
  canonicalPath="/centro"
  image={heroImage}
>
  <Hero
    title={page.data.heroTitle ?? page.data.title}
    intro={page.data.heroIntro ?? page.data.description}
    image={heroImage}
    imageAlt="Instalaciones de Centro Medico Miraverde"
  />

  <Section title="Sobre nosotros">
    <div class="split-layout">
      <div class="prose">
        <Content />
      </div>

      <div class="contact-tiles">
        <div class="contact-tile">
          <div class="certification-card__icon" aria-hidden="true" style="margin-bottom: 1rem;">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              <path d="M9 12l2 2 4-4"></path>
            </svg>
          </div>
          <h3 style="margin-top:0;">Centro medico autorizado</h3>
          <p>Trabajamos bajo los criterios del <strong>Servicio Canario de Salud</strong>, garantizando los mas altos estandares de profesionalismo y seguridad médica.</p>
        </div>

        <div class="contact-tile">
          <h3 style="margin-top:0;">{site.shortAddress}</h3>
          <p style="margin-bottom: 1rem;">Estamos en Costa Adeje, con acceso sencillo y zona de aparcamiento para pacientes de Adeje, Los Cristianos y Las Americas.</p>
          {site.openingHours.map((item) => (
            <p style="margin: 0;"><strong>Horario:</strong> {item}</p>
          ))}
          <div class="button-row" style="margin-top: 1.5rem;">
            <a class="button button--ghost" href={site.googleMapsDirectionsUrl} target="_blank" rel="noreferrer">Como llegar en Google Maps</a>
          </div>
        </div>
      </div>
    </div>
  </Section>

  {gallery.length > 0 && (
    <Section title="Espacios e instalaciones" class="section--alternate">
      <div class="gallery-grid">
        {gallery.map((image) => (
          <figure class="gallery-card">
            <img src={image.src} alt={image.alt} loading="lazy" />
          </figure>
        ))}
      </div>
    </Section>
  )}

  <WhatsAppCTA title="Consulta la especialidad adecuada" description="Escribenos por WhatsApp y te orientamos segun tu caso y disponibilidad." />
</BaseLayout>

<style>
  .split-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
    margin-bottom: 2rem;
  }

  .certification-card__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 1.1rem;
    background: rgba(138, 154, 134, 0.12);
    border: 1px solid rgba(138, 154, 134, 0.18);
    color: var(--brand-dark);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .gallery-card {
    margin: 0;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    aspect-ratio: 4 / 3;
  }

  .gallery-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .gallery-card:hover img {
    transform: scale(1.03);
  }

  @media (max-width: 960px) {
    .split-layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
